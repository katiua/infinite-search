{
  "name": "infinite-search",
  "description": "A chrome extension that enables infinite scrolling for search results.",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write . ",
    "prepare": "husky"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.1.37",
    "@types/node": "^25.5.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.62.1",
    "unocss": "^66.7.4",
    "vite": "^8.0.0",
    "vite-plugin-zip-pack": "^1.2.4"
  }
